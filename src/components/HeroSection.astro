---
// HeroSection — Main header with title, subtitle, and CTA
---

<header class="hero-section visible">
    <div class="hero-content">
        <span class="hero-pretitle">Automatización e IA para empresas</span>
        <h1 class="hero-title">Deja de pagar por trabajo que una automatización haría mejor.</h1>
        <p class="hero-subtitle">
            Diseñamos sistemas con IA que ahorran tiempo, reducen costes y escalan contigo &mdash; sin sumar nóminas.
        </p>
        <div class="hero-buttons">
            <a href="#consulting" class="cta-button">Consultoría gratuita</a>
            <a href="#services" class="cta-button">Ver cómo trabajamos &darr;</a>
        </div>
    </div>
    <div class="hero-image-placeholder">
        <!-- Espacio derecho reservado para futura ilustración, imagen o mockup -->
    </div>
</header>
<div class="hero-divider"></div>

<style>
    .hero-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 40px 0 100px 0;
        text-align: left;
        gap: 40px;
    }

    .hero-pretitle {
        text-transform: none; /* Según la imagen no es estrictamente uppercase sino Title Case/Sentence text regular */
        color: var(--secondary-color);
        display: block;
        margin-top: 25px;
        font-weight: 600;
        font-size: 1.1rem;
        font-family: 'Inter', sans-serif;
        opacity: 0.8;
    }

    .hero-content {
        flex: 0 0 55%;
        max-width: 650px;
        z-index: 2;
        padding-left: 20px;
    }

    .hero-title {
        font-size: clamp(40px, 5vw, 65px);
        line-height: 1.15;
        margin-bottom: 25px;
        color: #111; /* Casi negro para máximo contraste como en la imagen */
        font-weight: 600; /* No demasiado bold, un semibold limpio */
        letter-spacing: -1.5px;
        font-family: 'Inter', sans-serif;
    }

    .hero-subtitle {
        font-size: clamp(18px, 1.8vw, 22px);
        color: var(--secondary-color);
        max-width: 500px;
        line-height: 1.5;
        margin-bottom: 45px;
        font-family: 'Inter', sans-serif;
        opacity: 0.9;
    }

    .hero-buttons {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }



    .hero-image-placeholder {
        flex: 1;
        min-height: 400px;
        /* El lado derecho queda vacío. Ocupa hasta el ~40-45% restante del ancho */
    }

    .hero-divider {
        width: 100%;
        height: 1px;
        background: transparent;
        margin-bottom: 60px; /* Generoso padding con calc */
    }

    @media (max-width: 1000px) {
        .hero-section {
            padding: 50px 0;
        }
        .hero-content {
            flex: 0 0 65%;
        }
    }

    @media (max-width: 768px) {
        .hero-section {
            flex-direction: column;
            padding: 40px 0 60px;
        }

        .hero-content {
            flex: 1 1 100%;
            max-width: 100%;
            padding-left: 0;
        }

        .hero-title {
            font-size: clamp(34px, 8vw, 42px);
        }

        .hero-image-placeholder {
            width: 100%;
            min-height: 50px; /* Reducido en móviles */
        }
        
        .hero-buttons {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
        }
        
        .cta-button {
            text-align: center;
            width: 100%;
        }
    }
</style>
